{
  "name": "prototo-app",
  "version": "0.2.4",
  "private": true,
  "description": "Prototo — custom Expo dev client. Designer canvas for proto start on Simulator and iPhone. Renders real iOS 26 Liquid Glass.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "test": "vitest run --passWithNoTests",
    "build:ios": "eas build --platform ios --profile development",
    "build:ios:sim": "eas build --platform ios --profile development-simulator",
    "build:ios:prod": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --latest",
    "release:simulator": "tsx scripts/release-simulator.ts",
    "release:all": "pnpm build:ios && pnpm build:ios:sim && pnpm release:simulator"
  },
  "dependencies": {
    "@expo/ui": "56.0.17",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-segmented-control/segmented-control": "2.5.7",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~56.0.11",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.6",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.17",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-maps": "~56.0.7",
    "expo-router": "~56.2.10",
    "expo-screen-orientation": "~56.0.5",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-updates": "~56.0.19",
    "expo-video": "~56.1.3",
    "expo-web-browser": "~56.0.5",
    "lottie-react-native": "~7.3.4",
    "proto-components": "workspace:*",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ease": "^0.7.2",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/cli": "^56.1.15",
    "@expo/config-plugins": "56.0.8",
    "@types/node": "^20.12.0",
    "@types/react": "~19.2.15",
    "@vitest/coverage-v8": "^2.1.4",
    "babel-preset-expo": "~56.0.15",
    "tsx": "^4.15.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.4"
  }
}
