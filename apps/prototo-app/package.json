{
  "name": "prototo-app",
  "version": "0.1.3",
  "private": true,
  "description": "Prototo — custom Expo dev client. Designer canvas for proto start on Simulator and iPhone. Renders real iOS 26 Liquid Glass.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "test": "vitest run",
    "build:ios": "eas build --platform ios --profile development",
    "build:ios:sim": "eas build --platform ios --profile development-simulator",
    "build:ios:prod": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --latest",
    "release:simulator": "tsx scripts/release-simulator.ts",
    "release:all": "pnpm build:ios && pnpm build:ios:sim && pnpm release:simulator"
  },
  "dependencies": {
    "@expo/ui": "55.0.17",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.26",
    "expo-audio": "~55.0.14",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.18",
    "expo-clipboard": "~55.0.13",
    "expo-dev-client": "~55.0.35",
    "expo-font": "~55.0.8",
    "expo-glass-effect": "~55.0.11",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-maps": "~55.0.19",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-video": "~55.0.17",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-ease": "^0.7.2",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/node": "^20.12.0",
    "@types/react": "~19.2.15",
    "@vitest/coverage-v8": "^2.1.4",
    "babel-preset-expo": "~55.0.22",
    "tsx": "^4.15.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.4"
  }
}
