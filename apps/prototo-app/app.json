{
  "expo": {
    "name": "Prototo",
    "slug": "prototo-app",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prototo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.sherizan.prototo",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:prototo.app",
        "appclips:prototo.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "MinimumOSVersion": "26.0",
        "NSLocalNetworkUsageDescription": "Prototo connects to your computer to load your live prototype previews.",
        "NSLocationWhenInUseUsageDescription": "Prototo uses your location for prototypes with maps or location features.",
        "NSPhotoLibraryUsageDescription": "Prototo accesses your photos for prototypes that let you pick an image.",
        "NSCameraUsageDescription": "Prototo uses the camera for prototypes that capture photos or video.",
        "NSMicrophoneUsageDescription": "Prototo uses the microphone for prototypes that record audio or video.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "launcher"
        }
      ],
      "expo-router",
      "expo-asset",
      "expo-audio",
      "expo-font",
      "expo-image",
      "expo-maps",
      "expo-video",
      [
        "react-native-app-clip",
        {
          "name": "Prototo",
          "bundleIdSuffix": "Clip",
          "targetSuffix": "Clip",
          "deploymentTarget": "26.0",
          "excludedPackages": [
            "react-native-svg",
            "@shopify/react-native-skia",
            "@react-native-community/blur",
            "lottie-react-native",
            "react-native-ease",
            "react-native-gesture-handler",
            "react-native-screens",
            "@shopify/flash-list",
            "react-native-webview",
            "@react-native-async-storage/async-storage",
            "expo-blur",
            "expo-image",
            "expo-image-picker",
            "expo-camera",
            "expo-video",
            "expo-audio",
            "expo-maps",
            "expo-location",
            "expo-linear-gradient",
            "expo-symbols",
            "expo-clipboard",
            "expo-dev-client"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df9296f8-5010-4dd9-9949-661da71ac820"
      }
    },
    "owner": "sherizan",
    "android": {
      "package": "com.sherizan.prototo"
    }
  }
}
