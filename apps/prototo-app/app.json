{
  "expo": {
    "name": "Prototo",
    "slug": "prototo-app",
    "version": "0.1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prototo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.sherizan.prototo",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:prototo.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "MinimumOSVersion": "26.0"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df9296f8-5010-4dd9-9949-661da71ac820"
      }
    },
    "owner": "sherizan"
  }
}
