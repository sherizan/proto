{
  "expo": {
    "name": "Prototo",
    "slug": "prototo-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "prototo",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": "prototo-56",
    "updates": {
      "url": "https://u.expo.dev/8c8ddf7d-1f6a-4b21-a7cc-116ec4d72c6d"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.sherizan.prototo",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:prototo.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "MinimumOSVersion": "26.0",
        "NSLocalNetworkUsageDescription": "Prototo connects to your computer to load your live prototype previews.",
        "NSLocationWhenInUseUsageDescription": "Prototo uses your location for prototypes with maps or location features.",
        "NSPhotoLibraryUsageDescription": "Prototo accesses your photos for prototypes that let you pick an image.",
        "NSCameraUsageDescription": "Prototo uses the camera for prototypes that capture photos or video.",
        "NSMicrophoneUsageDescription": "Prototo uses the microphone for prototypes that record audio or video.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent",
          "showMenuAtLaunch": false,
          "skipOnboarding": true,
          "toolsButton": false
        }
      ],
      "expo-router",
      "expo-apple-authentication",
      "expo-asset",
      "expo-audio",
      "expo-font",
      "expo-image",
      "expo-maps",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df9296f8-5010-4dd9-9949-661da71ac820"
      }
    },
    "owner": "sherizan",
    "android": {
      "package": "com.sherizan.prototo"
    }
  }
}
