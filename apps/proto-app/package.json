{
  "name": "proto-app",
  "version": "0.1.0",
  "private": true,
  "description": "Proto custom dev client — Liquid Glass-capable iOS dev client for Proto prototypes",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "build:ios": "eas build --platform ios --profile development",
    "build:ios:sim": "eas build --platform ios --profile development-simulator"
  },
  "dependencies": {
    "@expo/ui": "^56.0.0",
    "expo": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-dev-client": "~56.0.14",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-router": "~56.2.5",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.2.15",
    "babel-preset-expo": "~56.0.11",
    "typescript": "^6.0.3"
  }
}
