{
  "name": "@sherizan/proto-cli",
  "version": "0.7.1",
  "description": "Proto CLI — the command-line tool inside a Proto project. `proto start` boots Metro and opens the iOS Simulator with your prototype.",
  "type": "module",
  "license": "MIT",
  "author": "Sherizan Sheikh",
  "homepage": "https://github.com/sherizan/proto#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sherizan/proto.git",
    "directory": "packages/proto-cli"
  },
  "bugs": {
    "url": "https://github.com/sherizan/proto/issues"
  },
  "keywords": [
    "proto",
    "expo",
    "react-native",
    "prototyping",
    "design-tool",
    "ios",
    "simulator",
    "liquid-glass"
  ],
  "bin": {
    "proto": "./dist/index.js",
    "proto-mcp": "./dist/mcp/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./design": {
      "types": "./dist/commands/design-template.d.ts",
      "import": "./dist/commands/design-template.js"
    },
    "./design-libraries": {
      "types": "./dist/commands/design-libraries.d.ts",
      "import": "./dist/commands/design-libraries.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cloudflared": "^0.5.3",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@sherizan/proto-compile": "workspace:*",
    "@types/node": "^20.12.0",
    "@types/qrcode-terminal": "^0.12.2"
  }
}
