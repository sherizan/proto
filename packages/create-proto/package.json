{
  "name": "create-proto",
  "version": "0.7.6",
  "description": "Scaffold a new Proto prototype: `npm create proto@latest myapp`. Describe a screen, watch your prototype run natively on iPhone — designer-first, paired with Claude Code.",
  "type": "module",
  "license": "MIT",
  "author": "Sherizan Sheikh",
  "homepage": "https://github.com/sherizan/proto#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sherizan/proto.git",
    "directory": "packages/create-proto"
  },
  "bugs": {
    "url": "https://github.com/sherizan/proto/issues"
  },
  "keywords": [
    "proto",
    "expo",
    "react-native",
    "prototyping",
    "design-tool",
    "ios",
    "simulator",
    "scaffold",
    "create"
  ],
  "bin": {
    "create-proto": "./dist/index.js"
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "sync-template": "tsx scripts/sync-template.ts",
    "prebuild": "tsx scripts/sync-template.ts",
    "guard:pnpm": "node scripts/guard-pnpm.mjs",
    "prepublishOnly": "node scripts/guard-pnpm.mjs && tsx scripts/sync-template.ts && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@sherizan/proto-cli": "workspace:^0.7.0",
    "fs-extra": "^11.2.0",
    "qrcode-terminal": "^0.12.0",
    "validate-npm-package-name": "^5.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/validate-npm-package-name": "^4.0.2",
    "tsx": "^4.15.0"
  }
}
