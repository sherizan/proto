{
  "expo": {
    "name": "{{name}}",
    "slug": "{{name}}",
    "version": "0.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "scheme": "prototo",
    "platforms": ["ios"],
    "ios": {
      "bundleIdentifier": "com.sherizan.prototo"
    },
    "plugins": [
      ["expo-dev-client", { "addGeneratedScheme": false }],
      "expo-router"
    ],
    "experiments": { "typedRoutes": true }
  }
}
