{
  "expo": {
    "name": "{{name}}",
    "slug": "{{name}}",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "scheme": "{{name}}",
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}
