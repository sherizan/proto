{
  "name": "proto-components",
  "version": "0.0.0",
  "private": true,
  "description": "Proto React Native component library — Screen, Stack, Text, Card, Button, Toggle, Nav, Modal, Divider, plus motion / gestures / lottie / canvas / svg subpaths",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./motion": "./src/motion/index.tsx",
    "./gestures": "./src/gestures/index.ts",
    "./lottie": "./src/lottie/index.tsx",
    "./canvas": "./src/canvas/index.ts",
    "./svg": "./src/svg/index.ts"
  },
  "types": "./src/index.ts",
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "@expo/ui": "*",
    "expo-glass-effect": "*",
    "react-native-safe-area-context": "*",
    "react-native-reanimated": "*",
    "react-native-gesture-handler": "*",
    "react-native-ease": "*",
    "lottie-react-native": "*",
    "@shopify/react-native-skia": "*",
    "react-native-svg": "*",
    "expo-haptics": "*",
    "@react-native-community/blur": "*"
  },
  "devDependencies": {
    "@expo/ui": "56.0.17",
    "expo-glass-effect": "~56.0.4",
    "@shopify/react-native-skia": "2.4.18",
    "react-native-svg": "15.15.3",
    "@react-native-community/blur": "4.4.1",
    "@types/react": "~19.2.15",
    "expo-haptics": "~55.0.14",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-ease": "^0.7.2",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2"
  }
}
