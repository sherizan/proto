{
  "manifestVersion": "1",
  "app": { "name": "Detail", "theme": "liquidGlass", "colorScheme": "system" },
  "initialScreen": "Detail",
  "screens": {
    "Detail": {
      "type": "Screen",
      "title": "Detail",
      "children": [
        {
          "type": "Stack",
          "gap": 16,
          "children": [
            {
              "type": "Card",
              "glass": true,
              "children": [
                { "type": "Text", "size": "headline", "value": "Detail" },
                { "type": "Text", "size": "caption", "color": "secondary", "value": "A glass card at the top" }
              ]
            },
            { "type": "Text", "size": "body", "value": "Body content goes here." },
            { "type": "Text", "size": "body", "color": "secondary", "value": "More secondary text below." }
          ]
        }
      ]
    }
  }
}
